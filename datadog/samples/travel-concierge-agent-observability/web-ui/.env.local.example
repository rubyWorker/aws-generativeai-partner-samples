# Web UI Environment Variables Configuration
# Copy this file to .env.local and update with your values
# Or run: ./scripts/setup-web-ui-env.sh to auto-generate from deployed stacks

# ===== AWS Configuration =====
VITE_AWS_REGION=us-east-1

# ===== Agent Runtime Configuration =====
VITE_AGENT_RUNTIME_ARN=your-agent-runtime-arn-here
VITE_AGENT_RUNTIME_ID=your-agent-runtime-id-here
VITE_AGENT_ENDPOINT_NAME=DEFAULT

# ===== Memory Configuration =====
VITE_MEMORY_ID=your-memory-id-here

# ===== Gateway Configuration =====
VITE_GATEWAY_URL=your-gateway-url-here
VITE_GATEWAY_ID=your-gateway-id-here

# ===== Google Maps API Key =====
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ===== Knowledge Base (Optional) =====
# VITE_KNOWLEDGE_BASE_ID=your-kb-id
# VITE_DOCUMENTS_BUCKET=your-documents-bucket
