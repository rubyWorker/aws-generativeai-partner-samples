# Datadog LLM Observability — Runtime secrets (injected by CDK from Secrets Manager)
# DD_API_KEY=           # From datadog/aig-agent/api-key in Secrets Manager
# DD_SITE=              # e.g. datadoghq.com or us5.datadoghq.com

# Static config (baked into Dockerfiles, override here if needed)
# DD_TRACE_ENABLED=true
# DD_LLMOBS_ENABLED=1
# DD_LLMOBS_AGENTLESS_ENABLED=1
# DD_LLMOBS_ML_APP=travel-concierge-agent
# DD_ENV=demo

# Per-service DD_SERVICE values (set in each Dockerfile):
#   supervisor-agent      — concierge_agent/supervisor_agent
#   travel-mcp-server     — concierge_agent/mcp_travel_tools
#   cart-mcp-server       — concierge_agent/mcp_cart_tools
#   itinerary-mcp-server  — concierge_agent/mcp_itinerary_tools
